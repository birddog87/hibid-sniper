# === Required ===
# Your HiBid login credentials
HIBID_EMAIL=your_email@example.com
HIBID_PASSWORD=your_password

# === Optional ===
# Discord webhook for win/loss/cap notifications (leave empty to disable)
DISCORD_WEBHOOK_URL=

# Your server's URL — used for CORS and bookmarklet fallback
# Set this to your LAN IP if accessing from other devices (e.g. http://192.168.1.100:8199)
APP_URL=http://localhost:8199

# Database path (inside the container — usually no need to change)
HIBID_DB_PATH=/app/data/hibid_sniper.db
